# Hosted: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Vercel: add the same two variables in Project → Settings → Environment Variables
# (Production + Preview), then redeploy — Vite bakes them in at build time.

# Local (Docker): run `npm run supabase:start`, then defaults are usually:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<copy from `npm run supabase:status` if the default JWT fails>
